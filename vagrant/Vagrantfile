# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|

  # Box base Oracle Linux 9
  config.vm.box = "oraclelinux/9"
  config.vm.box_url = "https://oracle.github.io/vagrant-projects/boxes/oraclelinux/9.json"

  # Configurações globais
  config.vm.provider "virtualbox" do |vb|
    vb.memory = 2048
    vb.cpus = 2
    vb.customize ["modifyvm", :id, "--usbehci", "off"]
  end

  # Desativa checagem de chave SSH
  config.ssh.insert_key = false

  # ============================================
  # VM01 — Master Keepalived
  # ============================================
  config.vm.define "vm01" do |vm01|
    vm01.vm.hostname = "vm01"
    vm01.vm.network "public_network",
      ip: "192.168.51.11",
      netmask: "255.255.255.224",
      bridge: "Hyper-V Virtual Ethernet Adapter #3"

    vm01.vm.provider "virtualbox" do |vb|
      vb.name = "vm01"

      # Disco adicional para particionamento
      disk = "vm01-disk.vdi"
      unless File.exist?(disk)
        vb.customize ["createhd",
          "--filename", disk,
          "--size", 15360]  # 15GB
      end
      vb.customize ["storageattach", :id,
        "--storagectl", "SATA Controller",
        "--port", 1,
        "--device", 0,
        "--type", "hdd",
        "--medium", disk]
    end

    # Provisiona com shell básico
    vm01.vm.provision "shell", inline: <<-SHELL
      echo "Configurando vm01..."
      hostnamectl set-hostname vm01
    SHELL
  end

  # ============================================
  # VM02 — JBoss
  # ============================================
  config.vm.define "vm02" do |vm02|
    vm02.vm.hostname = "vm02"
    vm02.vm.network "public_network",
      ip: "192.168.51.12",
      netmask: "255.255.255.224",
      bridge: "Hyper-V Virtual Ethernet Adapter #3"

    vm02.vm.provider "virtualbox" do |vb|
      vb.name = "vm02"
      vb.memory = 2048

      disk = "vm02-disk.vdi"
      unless File.exist?(disk)
        vb.customize ["createhd",
          "--filename", disk,
          "--size", 15360]
      end
      vb.customize ["storageattach", :id,
        "--storagectl", "SATA Controller",
        "--port", 1,
        "--device", 0,
        "--type", "hdd",
        "--medium", disk]
    end

    vm02.vm.provision "shell", inline: <<-SHELL
      echo "Configurando vm02..."
      hostnamectl set-hostname vm02
    SHELL
  end

  # ============================================
  # VM03 — Iptables
  # ============================================
  config.vm.define "vm03" do |vm03|
    vm03.vm.hostname = "vm03"
    vm03.vm.network "public_network",
      ip: "192.168.51.13",
      netmask: "255.255.255.224",
      bridge: "Hyper-V Virtual Ethernet Adapter #3"

    vm03.vm.provider "virtualbox" do |vb|
      vb.name = "vm03"

      disk = "vm03-disk.vdi"
      unless File.exist?(disk)
        vb.customize ["createhd",
          "--filename", disk,
          "--size", 15360]
      end
      vb.customize ["storageattach", :id,
        "--storagectl", "SATA Controller",
        "--port", 1,
        "--device", 0,
        "--type", "hdd",
        "--medium", disk]
    end

    vm03.vm.provision "shell", inline: <<-SHELL
      echo "Configurando vm03..."
      hostnamectl set-hostname vm03
    SHELL

    # Roda o Ansible depois de criar as 3 VMs
    vm03.vm.provision "ansible" do |ansible|
      ansible.playbook = "../ansible/site.yml"
      ansible.inventory_path = "../ansible/inventory/hosts.yml"
      ansible.limit = "all"
      ansible.verbose = "v"
    end
  end

end
